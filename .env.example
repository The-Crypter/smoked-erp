# SMOKED! ERP - Configurações de Ambiente
# Copie este arquivo para .env e ajuste os valores

# Segurança (MUDE EM PRODUÇÃO!)
SECRET_KEY=smoked-erp-change-this-in-production

# Banco de Dados
DATABASE_URL=sqlite:///database/smoked.db

# Ambiente
FLASK_ENV=development
# FLASK_ENV=production

# Empresa
EMPRESA_NOME=Smoked!
EMPRESA_SLOGAN=Defumados Artesanais de Qualidade

# Servidor
HOST=0.0.0.0
PORT=5000

# Debug (DESATIVE EM PRODUÇÃO!)
DEBUG=True